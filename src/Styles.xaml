                                Style="{DynamicResource MaterialDesignCalendarItemPortrait}"
                                Foreground="{x:Static wpfTheme:DidTheme.DatePickerForeground}" />
                </Border>
              </ControlTemplate>
            </Setter.Value>
          </Setter>
        </Style>
      </Setter.Value>
    </Setter>
