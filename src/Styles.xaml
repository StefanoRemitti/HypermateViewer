            <StackPanel Orientation="Horizontal" Grid.Row="0">

              <dxg:GridSearchControl
                x:Name="PART_SearchControl"
                HorizontalAlignment="Left"
                VerticalAlignment="Center"
                Visibility="Visible"
                FontSize="18"
                ShowSearchPanelNavigationButtons="False"
                ShowSearchPanelMode="Always"
                ShowFindButton="False"
                ShowClearButton="True"
                ShowMRUButton="False"
                Width="430"
                Height="60"
                Margin="0,0,0,0"
                FilterCondition="Contains" />

            </StackPanel>

            <StackPanel Orientation="Horizontal"
                        Grid.Row="0"
                        VerticalAlignment="Center"
                        Height="75"
                        HorizontalAlignment="Center"
                        x:Name="PART_ButtonContainer"
                        Margin="0 0 0 10" />
            <dx:SimpleButton
              Grid.Row="0"
              Margin="0 0 10 0"
              HorizontalAlignment="Right"
              VerticalAlignment="Center"
              Focusable="False"
              Glyph="{dxc:SvgImageSource Uri='pack://application:,,,/DevExpress.Images.v21.1;component/SvgImages/Icon Builder/Actions_Table.svg'}"
              Style="{StaticResource SimpleButtonPrimeStyle}"
              dxb:BarManager.MenuShowMouseButton="LeftButton"
              dxb:BarManager.DXContextMenuPlacement="Bottom">
              <dxb:BarManager.DXContextMenu>
                <dxb:PopupMenu>
                  <dxb:PopupMenu.Items>
                    <dxb:BarButtonItem
                      x:Name="PART_ColumnChooser"
                      Content="{helpers:PrimeStringResources StrColumnChooser}"
                      Glyph="{dxc:DXImage Image=ContentArrangeInColums_32x32.png}"
                      Margin="5" />
                    <dxb:BarButtonItem
                      x:Name="PART_Clear"
                      Content="{helpers:PrimeStringResources StrClearFilters}"
                      Glyph="{dxc:DXImage Image=ClearFilter_32x32.png}"
                      Margin="5" />
                    <dxb:BarButtonItem
                      x:Name="PART_GridExport"
                      Content="{helpers:PrimeStringResources StrGridExport}"
                      Glyph="{dxc:DXImage Image=ExportFile_32x32.png}"
                      Margin="5" />
                    <dxb:BarButtonItem
                      x:Name="PART_BestFitAllColumns"
                      Content="{helpers:PrimeStringResources StrBestFitAllColumns}"
                      Glyph="{dxc:DXImage Image=BestFit_32x32.png}"
                      GlyphAlignment="Left"
                      Margin="5" />
                    <dxb:BarButtonItem
                      x:Name="PART_FactoryReset"
                      Content="{helpers:PrimeStringResources StrFactoryReset}"
                      Glyph="{dxc:DXImage Image=Reset_32x32.png}"
                      GlyphAlignment="Left"
                      Margin="5" />
                    <dxb:BarButtonItem
                      x:Name="PART_Refresh"
                      Content="{helpers:PrimeStringResources StrRefresh}"
                      Glyph="{dxc:DXImage Image=Refresh_32x32.png}"
                      GlyphAlignment="Left"
                      Margin="5" />
                  </dxb:PopupMenu.Items>
                </dxb:PopupMenu>
              </dxb:BarManager.DXContextMenu>
            </dx:SimpleButton>


            <Grid Grid.Row="1" x:Name="PART_GridControlContainer" />
          </Grid>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

