  <Style TargetType="dxb:BarEditItemLinkControl">
    <Setter Property="HorizontalAlignment" Value="Left"/>
    <Setter Property="Margin" Value="10,0,10,0"/>
  </Style>
  <Style TargetType="{x:Type ribbon:GridRibbon}">
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="{x:Type ribbon:GridRibbon}">
          <Grid>

            <dxr:RibbonControl Grid.Row="0" ToolbarShowMode="Default"
                               ShowApplicationButton="False"
                               RibbonStyle="Office2019"
                               RibbonHeaderVisibility="Collapsed"
                               IsSimplified="True"
                               AllowCustomization="False"
                               AllowAddingToToolbar="False"
                               x:Name="RibbonControl">

              <dxr:RibbonPageCategory>
                <dxr:RibbonPage x:Name="PART_RibbonPage">
                  <dxr:RibbonPageGroup Caption="{helpers:PrimeStringResources StrSearch}" HideWhenEmpty="True" x:Name="PART_SearchGroupContainer">
                    <dxb:BarEditItem EditWidth="300" x:Name="PART_GridSearchControl" >

                      <dxb:BarEditItem.EditSettings>
                          <dxe:ButtonEditSettings AllowDefaultButton="False" NullText="{helpers:PrimeStringResources StrSearch}">  
                            <dxe:ButtonEditSettings.Buttons>  
                              <dxe:ButtonInfo GlyphKind="Cancel" >
                                <b:Interaction.Triggers>
                                  <b:EventTrigger EventName="Click">
                                    <b:ChangePropertyAction 
                                      TargetName="PART_GridSearchControl" 
                                      TargetObject="{Binding ElementName=PART_GridSearchControl}"
                                      PropertyName="EditValue" Value="{x:Null}"/>
                                  </b:EventTrigger>
                                </b:Interaction.Triggers>           
                              </dxe:ButtonInfo>                     
                            </dxe:ButtonEditSettings.Buttons>  
                          </dxe:ButtonEditSettings>  
                        </dxb:BarEditItem.EditSettings>
                      </dxb:BarEditItem>
                  </dxr:RibbonPageGroup>

                    <dxr:RibbonPageGroup x:Name="PART_DefaultControls" Caption="{helpers:PrimeStringResources StrGridCommands}">


                      <ribbon:BarButtonItemPrime x:Name="PART_ColumnChooser"
                                                 Content="{helpers:PrimeStringResources StrColumnChooser}"
                                                 ToolTip="{helpers:PrimeStringResources StrColumnChooser}"
                                                 Path="{StaticResource IcoColumnChooser}">
                        <ribbon:BarButtonItemPrime.Style>
                          <Style TargetType="{x:Type ribbon:BarButtonItemPrime}">
                            <Style.Triggers>
                              <DataTrigger Binding="{Binding IsSimplified, ElementName=RibbonControl}" Value="True">
                                <Setter Property="RibbonStyle" Value="SmallWithoutText" />
                              </DataTrigger>
                              <DataTrigger Binding="{Binding IsSimplified, ElementName=RibbonControl}" Value="False">
                                <Setter Property="RibbonStyle" Value="Default" />
                              </DataTrigger>
                            </Style.Triggers>
                          </Style>
                        </ribbon:BarButtonItemPrime.Style>
                      </ribbon:BarButtonItemPrime>
                      <ribbon:BarCheckItemPrime x:Name="PART_Clear"
                                                Content="{helpers:PrimeStringResources StrClearFilters}"
                                                ToolTip="{helpers:PrimeStringResources StrClearFilters}"
                                                Path="{StaticResource IcoClearFilters}">
                        <ribbon:BarCheckItemPrime.Style>
                          <Style TargetType="{x:Type ribbon:BarCheckItemPrime}">
                            <Style.Triggers>
                              <DataTrigger Binding="{Binding IsSimplified, ElementName=RibbonControl}" Value="True">
                                <Setter Property="RibbonStyle" Value="SmallWithoutText" />
                              </DataTrigger>
                              <DataTrigger Binding="{Binding IsSimplified, ElementName=RibbonControl}" Value="False">
                                <Setter Property="RibbonStyle" Value="Default" />
                              </DataTrigger>
                            </Style.Triggers>
                          </Style>
                        </ribbon:BarCheckItemPrime.Style>
                      </ribbon:BarCheckItemPrime>
                      <ribbon:BarButtonItemPrime x:Name="PART_GridExport"
                                                 Content="{helpers:PrimeStringResources StrGridExport}"
                                                 ToolTip="{helpers:PrimeStringResources StrGridExport}"
                                                 Path="{StaticResource IcoExport}">
                        <ribbon:BarButtonItemPrime.Style>
                          <Style TargetType="{x:Type ribbon:BarButtonItemPrime}">
                            <Style.Triggers>
                              <DataTrigger Binding="{Binding IsSimplified, ElementName=RibbonControl}" Value="True">
                                <Setter Property="RibbonStyle" Value="SmallWithoutText" />
                              </DataTrigger>
                              <DataTrigger Binding="{Binding IsSimplified, ElementName=RibbonControl}" Value="False">
                                <Setter Property="RibbonStyle" Value="Default" />
                              </DataTrigger>
                            </Style.Triggers>
                          </Style>
                        </ribbon:BarButtonItemPrime.Style>
                      </ribbon:BarButtonItemPrime>
                      <ribbon:BarButtonItemPrime x:Name="PART_BestFitAllColumns"
                                                 Content="{helpers:PrimeStringResources StrBestFitAllColumns}"
                                                 ToolTip="{helpers:PrimeStringResources StrBestFitAllColumns}"
                                                 Path="{StaticResource IcoBestFit}">
                        <ribbon:BarButtonItemPrime.Style>
                          <Style TargetType="{x:Type ribbon:BarButtonItemPrime}">
                            <Style.Triggers>
                              <DataTrigger Binding="{Binding IsSimplified, ElementName=RibbonControl}" Value="True">
                                <Setter Property="RibbonStyle" Value="SmallWithoutText" />
                              </DataTrigger>
                              <DataTrigger Binding="{Binding IsSimplified, ElementName=RibbonControl}" Value="False">
                                <Setter Property="RibbonStyle" Value="Default" />
                              </DataTrigger>
                            </Style.Triggers>
                          </Style>
                        </ribbon:BarButtonItemPrime.Style>
                      </ribbon:BarButtonItemPrime>
                      <ribbon:BarButtonItemPrime x:Name="PART_FactoryReset"
                                                 Content="{helpers:PrimeStringResources StrFactoryReset}"
                                                 ToolTip="{helpers:PrimeStringResources StrFactoryReset}"
                                                 Path="{StaticResource IcoFactoryReset}">
                        <ribbon:BarButtonItemPrime.Style>
                          <Style TargetType="{x:Type ribbon:BarButtonItemPrime}">
                            <Style.Triggers>
                              <DataTrigger Binding="{Binding IsSimplified, ElementName=RibbonControl}" Value="True">
                                <Setter Property="RibbonStyle" Value="SmallWithoutText" />
                              </DataTrigger>
                              <DataTrigger Binding="{Binding IsSimplified, ElementName=RibbonControl}" Value="False">
                                <Setter Property="RibbonStyle" Value="Default" />
                              </DataTrigger>
                            </Style.Triggers>
                          </Style>
                        </ribbon:BarButtonItemPrime.Style>
                      </ribbon:BarButtonItemPrime>

                    </dxr:RibbonPageGroup>

                    <dxr:RibbonPageGroup Caption="{helpers:PrimeStringResources StrCommands}"
                                         x:Name="PART_CustomButtonContainer"
                                         HideWhenEmpty="True" />

                </dxr:RibbonPage>
              </dxr:RibbonPageCategory>
            </dxr:RibbonControl>
          </Grid>

        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

</ResourceDictionary>